        "J104": ["Hades", "PC", "rol", "T", False, "Supergiant Games"],
        "J105": ["Among Us", "PC", "estrategia", "E", True, "InnerSloth"],
        "J106": ["Gran Turismo 7", "PS5", "carreras", "E", True, "Polyphony Digital"],
        "J107": ["It Takes Two", "PS5", "aventura", "T", True, "Hazelight Studios"],
    }

    inventario = {
        "J100": [19990, 5],
